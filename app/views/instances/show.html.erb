<% content_for(:title, "#{@instance.instance_type} — #{@instance.provider.name} Pricing") %>

<div class="space-y-6">
  <div class="flex items-center space-x-2 text-sm text-gray-500">
    <%= link_to "← Back to instances", instances_path, class: "hover:text-gray-700" %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <div class="p-6">
      <div class="flex items-center justify-between mb-6">
        <div>
          <div class="flex items-center space-x-3">
            <h1 class="text-2xl font-bold text-gray-900"><%= @instance.instance_type %></h1>
            <%= provider_badge(@instance.provider) %>
          </div>
          <p class="text-sm text-gray-500 mt-1"><%= @instance.family %> · <%= @instance.region %></p>
        </div>
        <div class="text-right">
          <p class="text-3xl font-bold text-gray-900"><%= format_price(@instance.price_per_hour) %><span class="text-sm font-normal text-gray-500">/hr</span></p>
          <p class="text-sm text-gray-500"><%= format_monthly(@instance.price_per_hour) %>/mo (730hrs)</p>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs font-medium text-gray-500 uppercase">vCPUs</p>
          <p class="text-2xl font-bold text-gray-900 mt-1"><%= @instance.vcpus %></p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs font-medium text-gray-500 uppercase">Memory</p>
          <p class="text-2xl font-bold text-gray-900 mt-1"><%= sprintf('%.1f', @instance.memory_gb) %> <span class="text-sm">GB</span></p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs font-medium text-gray-500 uppercase">Price per vCPU</p>
          <p class="text-2xl font-bold text-gray-900 mt-1"><%= format_price(@instance.price_per_vcpu) %><span class="text-sm">/hr</span></p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <p class="text-xs font-medium text-gray-500 uppercase">Price per GB</p>
          <p class="text-2xl font-bold text-gray-900 mt-1"><%= format_price(@instance.price_per_gb_memory) %><span class="text-sm">/hr</span></p>
        </div>
      </div>
    </div>
  </div>

  <% if @similar.any? %>
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <div class="p-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Similar Instances</h2>
        <p class="text-sm text-gray-500">Instances with comparable vCPU count</p>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Provider</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Instance Type</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">vCPUs</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Memory</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Hourly</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Monthly</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @similar.each do |instance| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3"><%= provider_badge(instance.provider) %></td>
              <td class="px-4 py-3 text-sm font-medium">
                <%= link_to instance.instance_type, instance_path(instance), class: "text-blue-600 hover:underline" %>
              </td>
              <td class="px-4 py-3 text-sm text-right"><%= instance.vcpus %></td>
              <td class="px-4 py-3 text-sm text-right"><%= sprintf('%.1f', instance.memory_gb) %> GB</td>
              <td class="px-4 py-3 text-sm text-right font-mono"><%= format_price(instance.price_per_hour) %></td>
              <td class="px-4 py-3 text-sm text-right font-mono"><%= format_monthly(instance.price_per_hour) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
