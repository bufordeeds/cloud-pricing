<% content_for(:title, "Request API Access — CloudPricing") %>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">Request API Access</h1>
  <p class="text-gray-600 mb-6">
    Get programmatic access to CloudPricing data. Submit your request and we'll review it — you'll receive an API key by email once approved.
  </p>

  <%= form_with(model: @api_key, url: api_key_requests_path, class: "space-y-4") do |f| %>
    <% if @api_key.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded text-sm">
        <ul class="list-disc list-inside">
          <% @api_key.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Your name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm", placeholder: "Jane Smith" %>
    </div>

    <div>
      <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm", placeholder: "jane@example.com" %>
    </div>

    <div>
      <%= f.submit "Request Access", class: "w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 font-medium text-sm cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-8 bg-gray-100 rounded-md p-4 text-sm text-gray-600">
    <h3 class="font-medium text-gray-900 mb-2">What you'll get</h3>
    <ul class="space-y-1">
      <li>Read-only JSON API for cloud instances and LLM model pricing</li>
      <li>100 requests per minute rate limit</li>
      <li>Bearer token authentication</li>
    </ul>
  </div>
</div>
