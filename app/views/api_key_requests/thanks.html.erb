<% content_for(:title, "Request Received — CloudPricing") %>

<div class="max-w-lg mx-auto text-center py-12">
  <div class="bg-green-50 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
    <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
    </svg>
  </div>
  <h1 class="text-2xl font-bold text-gray-900 mb-2">Request Received</h1>
  <p class="text-gray-600 mb-6">
    Your API access request has been submitted. You'll receive an email with your API key once it's been reviewed and approved.
  </p>
  <%= link_to "Back to CloudPricing", root_path, class: "text-blue-600 hover:underline text-sm" %>
</div>
